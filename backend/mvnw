#!/bin/sh
# Maven wrapper shell script — downloads Maven if not present, then delegates to it.
# Do not edit this file; it is managed by the Maven Wrapper plugin.

set -e

# Locate the script directory (handles symlinks)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
MAVEN_WRAPPER_JAR="$SCRIPT_DIR/.mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES="$SCRIPT_DIR/.mvn/wrapper/maven-wrapper.properties"

# Read distributionUrl from properties
DISTRIBUTION_URL=$(grep "^distributionUrl" "$MAVEN_WRAPPER_PROPERTIES" | cut -d= -f2-)

# Derive local Maven home from the distribution URL
MAVEN_HOME="$HOME/.m2/wrapper/dists/$(basename "$DISTRIBUTION_URL" .zip)"

if [ ! -d "$MAVEN_HOME" ]; then
    echo "Downloading Maven from $DISTRIBUTION_URL ..."
    mkdir -p "$MAVEN_HOME"
    if command -v curl > /dev/null 2>&1; then
        curl -fsSL "$DISTRIBUTION_URL" -o "$MAVEN_HOME/maven.zip"
    elif command -v wget > /dev/null 2>&1; then
        wget -q "$DISTRIBUTION_URL" -O "$MAVEN_HOME/maven.zip"
    else
        echo "ERROR: curl or wget is required to download Maven." >&2
        exit 1
    fi
    unzip -q "$MAVEN_HOME/maven.zip" -d "$MAVEN_HOME"
    rm "$MAVEN_HOME/maven.zip"
fi

# Find the mvn executable inside the unpacked distribution
MVN_EXEC=$(find "$MAVEN_HOME" -name "mvn" -type f | head -1)
if [ -z "$MVN_EXEC" ]; then
    echo "ERROR: Could not locate mvn executable in $MAVEN_HOME" >&2
    exit 1
fi

exec "$MVN_EXEC" "$@"
